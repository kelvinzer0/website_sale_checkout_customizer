<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Inject a hidden data node carrying the configured options so the
        client-side JS can read them without an extra RPC.
        JS-based hiding is used (instead of server-side invisible=1) so
        that toggling the Settings values does not require a view edit.
        Odoo 17 note: the checkout form lives in `website_sale.address`.
        The actual <form> element has class `checkout_autoformat`.
    -->
    <template id="checkout_customizer_data" name="Checkout Customizer Data"
              inherit_id="website_sale.address">
        <xpath expr="//form[hasclass('checkout_autoformat')]" position="inside">
            <t t-set="cfg" t-value="env['ir.config_parameter'].sudo().get_param"/>
            <t t-set="allowed_ids_raw"
               t-value="cfg('website_sale_checkout_customizer.checkout_allowed_country_ids', '')"/>
            <t t-set="default_country_id"
               t-value="cfg('website_sale_checkout_customizer.checkout_default_country_id', '')"/>
            <t t-set="hide_city"
               t-value="cfg('website_sale_checkout_customizer.checkout_hide_city', '')"/>
            <t t-set="hide_zip"
               t-value="cfg('website_sale_checkout_customizer.checkout_hide_zip', '')"/>
            <t t-set="hide_company_name"
               t-value="cfg('website_sale_checkout_customizer.checkout_hide_company_name', '')"/>
            <input type="hidden"
                   id="checkout_customizer_config"
                   t-att-data-allowed-country-ids="allowed_ids_raw or ''"
                   t-att-data-default-country-id="default_country_id or ''"
                   t-att-data-hide-city="'1' if hide_city in ('True', 'true', '1', True) else '0'"
                   t-att-data-hide-zip="'1' if hide_zip in ('True', 'true', '1', True) else '0'"
                   t-att-data-hide-company-name="'1' if hide_company_name in ('True', 'true', '1', True) else '0'"
            />
        </xpath>
    </template>

    <!--
        SERVER-SIDE REMOVAL OF THE COMPANY NAME FIELD
        =============================================
        Replaces the entire div wrapper that contains
        the input named "company_name" (plus its label and the small
        "cannot edit company name" hint) with nothing, so the field is
        ABSENT from the rendered HTML — not merely hidden via CSS/JS.

        This applies to BOTH the create mode (/shop/address) and the
        edit mode (/shop/address?mode=billing&partner_id=N) because
        both branches render the same inherited template.

        The XPath //div[input[@name='company_name']] matches the
        wrapper div on the parent (website_sale.address) raw arch. The
        matching div is unique inside the template (only one input has
        name="company_name"), so position="replace" with empty content
        is safe.

        Note: we deliberately do NOT touch the surrounding
        t-if="website._display_partner_b2b_fields()" block because
        it also contains the VAT field; only the company_name wrapper
        is removed.

        The companion Settings toggle checkout_hide_company_name
        remains in place and is still respected by the JS as a
        defense-in-depth fallback (it will simply find no element to
        hide after this XPath is applied).
    -->
    <template id="checkout_customizer_remove_company_name"
              name="Checkout Customizer: Remove Company Name Field (server-side)"
              inherit_id="website_sale.address">
        <xpath expr="//div[input[@name='company_name']]" position="replace"/>
    </template>

    <!--
        IMPORTANT NOTE (for future maintainers, not enforced by this file):

        The `warunglakku.simple_checkout` view (created via the website
        editor in production, NOT shipped from a module) replaces the
        standard `<input name="street">` with a `<textarea>` and
        originally populated its value via `checkout.get('street', '')`.

        That expression works when `checkout` is a dict (new address
        with no partner_id) but crashes with
            AttributeError: 'res.partner' object has no attribute 'get'
        when the controller hands us a res.partner record (editing an
        existing address via /shop/address?partner_id=N&mode=billing).

        The fix `checkout['street'] if 'street' in checkout else ''` is
        polymorphic and works for both dict and res.partner record.

        We CANNOT ship this fix as an xpath in this module because
        Odoo's view validation during module upgrade matches the xpath
        against the parent's RAW arch (which still has `<input>`), not
        the combined arch (which has the `<textarea>` after
        warunglakku.simple_checkout is applied). An xpath targeting
        `//textarea[@name='street']` therefore fails validation.

        The fix is therefore applied directly to the production DB via
        scripts/patch_simple_checkout_view.py. Re-run that script after
        any DB restore or after warunglakku.simple_checkout is edited
        via the website editor.
    -->
</odoo>
