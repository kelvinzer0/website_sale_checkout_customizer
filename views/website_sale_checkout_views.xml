<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Inject a hidden data node carrying the configured options so the
        client-side JS can read them without an extra RPC.
        JS-based hiding is used (instead of server-side invisible=1) so
        that toggling the Settings values does not require a view edit.
        Odoo 17 note: the checkout form lives in `website_sale.address`.
        The actual <form> element has class `checkout_autoformat`.
    -->
    <template id="checkout_customizer_data" name="Checkout Customizer Data"
              inherit_id="website_sale.address">
        <xpath expr="//form[hasclass('checkout_autoformat')]" position="inside">
            <t t-set="cfg" t-value="env['ir.config_parameter'].sudo().get_param"/>
            <t t-set="allowed_ids_raw"
               t-value="cfg('website_sale_checkout_customizer.checkout_allowed_country_ids', '')"/>
            <t t-set="default_country_id"
               t-value="cfg('website_sale_checkout_customizer.checkout_default_country_id', '')"/>
            <t t-set="hide_city"
               t-value="cfg('website_sale_checkout_customizer.checkout_hide_city', '')"/>
            <t t-set="hide_zip"
               t-value="cfg('website_sale_checkout_customizer.checkout_hide_zip', '')"/>
            <t t-set="hide_company_name"
               t-value="cfg('website_sale_checkout_customizer.checkout_hide_company_name', '')"/>
            <input type="hidden"
                   id="checkout_customizer_config"
                   t-att-data-allowed-country-ids="allowed_ids_raw or ''"
                   t-att-data-default-country-id="default_country_id or ''"
                   t-att-data-hide-city="'1' if hide_city in ('True', 'true', '1', True) else '0'"
                   t-att-data-hide-zip="'1' if hide_zip in ('True', 'true', '1', True) else '0'"
                   t-att-data-hide-company-name="'1' if hide_company_name in ('True', 'true', '1', True) else '0'"
            />
        </xpath>
    </template>
</odoo>
