<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_checkout_customizer" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.checkout.customizer</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Anchor on the existing "Website Info" block (Odoo 17 uses
                 id="website_info_settings", NOT "website_info_settings_container") -->
            <xpath expr="//block[@id='website_info_settings']" position="after">
                <block title="Checkout Customizer" id="checkout_customizer_settings_block">
                    <setting id="checkout_hide_city_setting"
                             string="Hide City Field"
                             help="Remove the City input from the website checkout form.">
                        <field name="checkout_hide_city"/>
                    </setting>
                    <setting id="checkout_hide_zip_setting"
                             string="Hide Zip / Postal Code Field"
                             help="Remove the Zip / Postal Code input from the website checkout form.">
                        <field name="checkout_hide_zip"/>
                    </setting>
                    <setting id="checkout_allowed_countries_setting"
                             string="Allowed Countries"
                             help="Restrict the country dropdown to this list. Leave empty to show all.">
                        <field name="checkout_allowed_country_ids" widget="many2many_tags"/>
                    </setting>
                    <setting id="checkout_default_country_setting"
                             string="Default Country"
                             help="Pre-selected country on the checkout form.">
                        <field name="checkout_default_country_id"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
