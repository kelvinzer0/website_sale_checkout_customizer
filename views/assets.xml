<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Asset bundle declaration so the JS file is shipped to the
        storefront on every checkout page. We hook into
        `web.assets_frontend` which is the standard bundle for
        website front-end resources.
    -->
    <template id="assets_frontend_checkout_customizer" name="Checkout Customizer Assets"
              inherit_id="web.assets_frontend">
        <xpath expr="." position="inside">
            <script type="text/javascript"
                    src="/website_sale_checkout_customizer/static/src/js/checkout_customizer.js"/>
        </xpath>
    </template>
</odoo>
